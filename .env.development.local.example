# Development env example for ngrok
# Choose ONE of the options below:
#
# Option A (recommended): point to the BACKEND root URL (no trailing /api), used by Vite proxy and axios
VITE_API_URL=https://<subdomain>.ngrok-free.app
#
# Option B (alternative): point axios directly to the API path (includes /api), bypassing Vite proxy
# VITE_API_BASE_URL=https://<subdomain>.ngrok-free.app/api

